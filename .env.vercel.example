# Set these in Vercel → Project → Settings → Environment Variables
# (Production + Preview + Development)

# REQUIRED on Vercel — SQLite does not persist on serverless
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=proxima_gov

# REQUIRED in production
SESSION_SECRET=generate-with-openssl-rand-base64-48-min-32-chars

# Demo OTP on screen (default: shown until SMS is wired up)
# Set to false only after integrating MSG91/Twilio via SMS_PROVIDER_API_KEY
# PROXIMA_DEMO_OTP=true

# Optional
# NEXT_PUBLIC_GEMINI_API_KEY=
# DATAGOVINDIA_API_KEY=
# SMS_PROVIDER_API_KEY=