# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to GitHub.

# Optional — Gemini AI for grievance responses
# NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Optional — data.gov.in open data API
# DATAGOVINDIA_API_KEY=your_datagovindia_api_key_here

# ── Data persistence (pick ONE) ───────────────────────────────────────
#
# DEFAULT — SQLite (zero setup, local file: backend/data/proxima.sqlite)
# No env vars needed.
#
# OPTION — MongoDB Atlas free tier
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=proxima_gov
#
# OPTION — Local MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB=proxima_gov
#
# Disable all persistence (demo mode, data resets on restart):
# PROXIMA_STORAGE=off

# Production session signing (recommended for deployment)
# SESSION_SECRET=generate-a-long-random-string-here